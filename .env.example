# App publica. En local usa http://localhost:3000; en Vercel usa tu dominio final.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Base de datos PostgreSQL/Supabase.
# Para Vercel usa una URL accesible desde Vercel y compatible con Prisma migrate.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Seguridad. Usa valores largos y diferentes. No los compartas ni los subas al repo.
QR_SECRET="cambia-esto-por-un-secreto-largo-para-firmar-los-qr"
AUTH_SECRET="cambia-esto-por-un-secreto-largo-para-sesiones"

# Reglas por defecto para QR nuevos.
DEFAULT_POINTS_PER_QR=75
DEFAULT_QR_EXPIRATION_DAYS=2

# Admin inicial. El seed seguro crea o actualiza este usuario.
ADMIN_EMAIL="admin@nocturne.test"
ADMIN_PASSWORD="cambia-esta-contrasena"

# Solo para desarrollo/demos. En produccion dejalo en false o no lo declares.
SEED_SAMPLE_DATA=false
